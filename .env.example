# Copy to .env and fill in. NEVER commit your real .env.
#
# The __client cookie: DevTools > Application > Cookies > https://higgsfield.ai
HIGGSFIELD_CLERK_COOKIE=

# Session id: DevTools > Console > window.Clerk.session.id  (starts with sess_)
HIGGSFIELD_SESSION_ID=sess_xxxxxxxxxxxxx

# Extra cookies forwarded to the API. The /jobs create endpoint is behind DataDome;
# without your browser's datadome cookie, POST /jobs/{model} returns a 403 captcha.
# Get it from DevTools > Console > document.cookie (copy at least the datadome=... part).
# This cookie rotates — refresh it if generation starts returning 403.
HIGGSFIELD_EXTRA_COOKIES=datadome=xxxxxxxx

# Match your plan's concurrent tier: 4 / 8 / 12 / 16
HIGGSFIELD_MAX_CONCURRENT=4

# Default image model when not specified
HIGGSFIELD_DEFAULT_MODEL=nano-banana-2

# One of: 1k / 2k / 4k
HIGGSFIELD_DEFAULT_RESOLUTION=2k

# Where downloads land
HIGGSFIELD_OUTPUT_DIR=./higgsfield_output

# DEBUG / INFO / WARNING / ERROR
HIGGSFIELD_LOG_LEVEL=INFO
